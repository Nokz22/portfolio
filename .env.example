# ── GitHub Integration ───────────────────────────────────────────
# Create a PAT at: github.com → Settings → Developer settings → Personal access tokens
# Permissions needed: public_repo (read-only is sufficient)
GITHUB_USERNAME=Nokz22
GITHUB_TOKEN=ghp_your_personal_access_token_here

# ── Email (contact form) ─────────────────────────────────────────
# Gmail: enable 2FA then create an App Password at myaccount.google.com/apppasswords
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_gmail_app_password_16chars
CONTACT_RECIPIENT_EMAIL=your_email@gmail.com

# ── CORS ─────────────────────────────────────────────────────────
# Dev: http://localhost:3000
# Production: your Railway frontend URL (e.g. https://portfolio-frontend-xxx.railway.app)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── Frontend ─────────────────────────────────────────────────────
# Dev: leave empty — Vite proxies /api/* to localhost:8080
# Production: your Railway backend URL (e.g. https://portfolio-backend-xxx.railway.app)
VITE_API_URL=

# ── Railway (CI/CD deploy) ────────────────────────────────────────
# Create at: railway.app → Account Settings → Tokens
# Add as GitHub secret: github.com/Nokz22/portfolio → Settings → Secrets → RAILWAY_TOKEN
RAILWAY_TOKEN=your_railway_token_here
